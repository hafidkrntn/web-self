---
/**
 * ProjectCards3D.astro
 * 3D floating project cards with parallax, tilt effects, and popup modal
 */
const projects = [
  {
    id: "denext",
    title: "IT Consultant Landing Page",
    description:
      "Refactored and modernized landing page for Denext IT Consultant.",
    fullDescription:
      "A modern and responsive IT consultant landing page redesigned with improved UI/UX, performance optimization, and clean code structure. The project focuses on clear service presentation, smooth user experience, and better content organization to support business credibility.",
    tech: ["HTML", "CSS", "JavaScript"],
    features: [
      "Modern responsive layout",
      "Improved UI/UX design",
      "Optimized performance",
      "Clean and maintainable codebase",
    ],
    link: "https://github.com",
    demo: "https://denext.id",
  },
  {
    id: "ai-dashboard",
    title: "AI Dashboard",
    description:
      "Analytics dashboard with machine learning insights and predictive models.",
    fullDescription:
      "An intelligent analytics platform that leverages TensorFlow for predictive modeling, featuring interactive D3.js visualizations, real-time data processing, and automated reporting with actionable insights.",
    tech: ["Vue.js", "Python", "TensorFlow", "D3.js"],
    features: [
      "ML predictions",
      "Interactive charts",
      "Real-time data",
      "Auto reports",
    ],
    gradient: "cyan",
    link: "https://github.com",
    demo: "https://demo.example.com",
  },
  {
    id: "banking-app",
    title: "Mobile Banking App",
    description:
      "Secure banking solution with biometric authentication and instant transfers.",
    fullDescription:
      "A secure mobile banking application with biometric authentication (Face ID & Touch ID), instant P2P transfers, bill payments, spending analytics, and push notifications for transaction alerts.",
    tech: ["React Native", "Firebase", "Stripe", "Node.js"],
    features: [
      "Biometric auth",
      "Instant transfers",
      "Bill payments",
      "Spending analytics",
    ],
    gradient: "pink",
    link: "https://github.com",
    demo: "https://demo.example.com",
  },
];
---

<section id="projects" class="projects section">
  <div class="container">
    <div class="section-header">
      <span class="section-label">Portfolio</span>
      <h2>Featured <span class="gradient-text">Projects</span></h2>
      <p class="section-description">
        A collection of projects that showcase my passion for creating
        beautiful, functional, and user-centric applications.
        <br /><strong style="color: var(--accent-blue);"
          >Click on a card to see details!</strong
        >
      </p>
    </div>

    <div class="projects-grid">
      {
        projects.map((project, index) => (
          <article
            class={`project-card project-card--${project.gradient}`}
            data-index={index}
            data-project={JSON.stringify(project)}
          >
            <div class="project-image">
              <div class="project-overlay">
                <span class="view-project">
                  <svg
                    width="24"
                    height="24"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                  >
                    <path d="M15 3h6v6M9 21H3v-6M21 3l-7 7M3 21l7-7" />
                  </svg>
                </span>
              </div>
            </div>
            <div class="project-content">
              <h3 class="project-title">{project.title}</h3>
              <p class="project-description">{project.description}</p>
              <div class="project-tech">
                {project.tech.map((tech) => (
                  <span class="tech-tag">{tech}</span>
                ))}
              </div>
            </div>
            <div class="project-glow" />
          </article>
        ))
      }
    </div>
  </div>
</section>

<!-- Project Modal -->
<div class="modal-overlay" id="project-modal">
  <div class="modal-container">
    <button class="modal-close" id="modal-close" aria-label="Close modal">
      <svg
        width="24"
        height="24"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
      >
        <path d="M18 6L6 18M6 6l12 12"></path>
      </svg>
    </button>

    <div class="modal-content">
      <div class="modal-header" id="modal-header">
        <!-- Dynamic gradient background -->
      </div>

      <div class="modal-body">
        <h2 class="modal-title" id="modal-title">Project Title</h2>
        <p class="modal-description" id="modal-description">
          Project description goes here.
        </p>

        <div class="modal-section">
          <h4>Key Features</h4>
          <div class="modal-features" id="modal-features">
            <!-- Features will be inserted here -->
          </div>
        </div>

        <div class="modal-section">
          <h4>Technologies Used</h4>
          <div class="modal-tech" id="modal-tech">
            <!-- Tech will be inserted here -->
          </div>
        </div>

        <div class="modal-actions">
          <a
            href="#"
            class="btn-primary"
            id="modal-link"
            target="_blank"
            rel="noopener noreferrer"
          >
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
              <path
                d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"
              ></path>
            </svg>
            <span>View Code</span>
          </a>
          <a
            href="#"
            class="btn-secondary"
            id="modal-demo"
            target="_blank"
            rel="noopener noreferrer"
          >
            <svg
              width="20"
              height="20"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
            >
              <path
                d="M18 13v6a2 2 0 01-2 2H5a2 2 0 01-2-2V8a2 2 0 012-2h6M15 3h6v6M10 14L21 3"
              ></path>
            </svg>
            <span>Live Demo</span>
          </a>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  function initProjectAnimations() {
    // Make sure elements are visible first
    gsap.set(".project-card", { opacity: 1, y: 0 });

    // Cards entrance animation
    gsap.from(".project-card", {
      scrollTrigger: {
        trigger: ".projects-grid",
        start: "top 85%",
        once: true,
      },
      y: 100,
      opacity: 0,
      duration: 0.8,
      stagger: 0.2,
      ease: "power3.out",
    });
  }

  // Wait for page to be fully loaded
  if (document.readyState === "complete") {
    initProjectAnimations();
    ScrollTrigger.refresh();
  } else {
    window.addEventListener("load", () => {
      initProjectAnimations();
      ScrollTrigger.refresh();
    });
  }

  // Modal elements
  const modal = document.getElementById("project-modal");
  const modalClose = document.getElementById("modal-close");
  const modalHeader = document.getElementById("modal-header");
  const modalTitle = document.getElementById("modal-title");
  const modalDescription = document.getElementById("modal-description");
  const modalFeatures = document.getElementById("modal-features");
  const modalTech = document.getElementById("modal-tech");
  const modalLink = document.getElementById("modal-link") as HTMLAnchorElement;
  const modalDemo = document.getElementById("modal-demo") as HTMLAnchorElement;

  // Gradient classes for modal header
  const gradientClasses: Record<string, string> = {
    purple: "linear-gradient(135deg, #1e1b4b 0%, #4c1d95 50%, #8b5cf6 100%)",
    cyan: "linear-gradient(135deg, #164e63 0%, #0e7490 50%, #06b6d4 100%)",
    pink: "linear-gradient(135deg, #4c1d42 0%, #be185d 50%, #ec4899 100%)",
  };

  // Open modal function
  function openModal(projectData: any) {
    if (
      !modal ||
      !modalHeader ||
      !modalTitle ||
      !modalDescription ||
      !modalFeatures ||
      !modalTech
    )
      return;

    // Set content
    modalHeader.style.background =
      gradientClasses[projectData.gradient] || gradientClasses.purple;
    modalTitle.textContent = projectData.title;
    modalDescription.textContent = projectData.fullDescription;

    // Set features
    modalFeatures.innerHTML = projectData.features
      .map((feature: string) => `<span class="feature-tag">${feature}</span>`)
      .join("");

    // Set tech
    modalTech.innerHTML = projectData.tech
      .map((tech: string) => `<span class="tech-tag">${tech}</span>`)
      .join("");

    // Set links
    modalLink.href = projectData.link;
    modalDemo.href = projectData.demo;

    // Show modal
    modal.classList.add("active");
    document.body.style.overflow = "hidden";

    // Animate in
    gsap.fromTo(
      modal.querySelector(".modal-container"),
      { scale: 0.8, opacity: 0 },
      { scale: 1, opacity: 1, duration: 0.4, ease: "back.out(1.7)" },
    );
  }

  // Close modal function
  function closeModal() {
    if (!modal) return;

    gsap.to(modal.querySelector(".modal-container"), {
      scale: 0.8,
      opacity: 0,
      duration: 0.3,
      ease: "power2.in",
      onComplete: () => {
        modal.classList.remove("active");
        document.body.style.overflow = "";
      },
    });
  }

  // Event listeners for project cards
  document.querySelectorAll(".project-card").forEach((card) => {
    const cardEl = card as HTMLElement;

    // Click to open modal
    cardEl.addEventListener("click", () => {
      const projectData = cardEl.dataset.project;
      if (projectData) {
        openModal(JSON.parse(projectData));
      }
    });

    // 3D tilt effect on hover
    cardEl.addEventListener("mousemove", (e) => {
      const rect = cardEl.getBoundingClientRect();
      const x = e.clientX - rect.left;
      const y = e.clientY - rect.top;
      const centerX = rect.width / 2;
      const centerY = rect.height / 2;

      const rotateX = (y - centerY) / 15;
      const rotateY = (centerX - x) / 15;

      gsap.to(cardEl, {
        rotateX: -rotateX,
        rotateY: rotateY,
        duration: 0.5,
        ease: "power2.out",
        transformPerspective: 1000,
      });

      // Move glow with cursor
      const glow = cardEl.querySelector(".project-glow") as HTMLElement;
      if (glow) {
        glow.style.opacity = "1";
        glow.style.left = `${x}px`;
        glow.style.top = `${y}px`;
      }
    });

    cardEl.addEventListener("mouseleave", () => {
      gsap.to(cardEl, {
        rotateX: 0,
        rotateY: 0,
        duration: 0.5,
        ease: "power2.out",
      });

      const glow = cardEl.querySelector(".project-glow") as HTMLElement;
      if (glow) {
        glow.style.opacity = "0";
      }
    });
  });

  // Close modal events
  modalClose?.addEventListener("click", closeModal);
  modal?.addEventListener("click", (e) => {
    if (e.target === modal) closeModal();
  });
  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape") closeModal();
  });
</script>

<style>
  .projects {
    position: relative;
    overflow: hidden;
  }

  .section-header {
    text-align: center;
    margin-bottom: 4rem;
  }

  .section-label {
    display: inline-block;
    padding: 0.5rem 1rem;
    background: var(--glass-bg);
    border: 1px solid var(--glass-border);
    border-radius: 50px;
    font-size: 0.875rem;
    color: var(--accent-blue);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: 1rem;
  }

  .section-description {
    max-width: 500px;
    margin: 1rem auto 0;
  }

  .projects-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(340px, 1fr));
    gap: 2rem;
    perspective: 1000px;
  }

  .project-card {
    position: relative;
    background: var(--glass-bg);
    border: 1px solid var(--glass-border);
    border-radius: 24px;
    overflow: hidden;
    transition: all var(--transition-base);
    transform-style: preserve-3d;
    cursor: pointer;
  }

  .project-card:hover {
    border-color: var(--glass-border-hover);
    transform: translateY(-10px);
  }

  .project-card--purple:hover {
    box-shadow: 0 25px 60px rgba(59, 130, 246, 0.25);
  }

  .project-card--cyan:hover {
    box-shadow: 0 25px 60px rgba(6, 182, 212, 0.25);
  }

  .project-card--pink:hover {
    box-shadow: 0 25px 60px rgba(236, 72, 153, 0.25);
  }

  .project-image {
    height: 200px;
    position: relative;
    overflow: hidden;
  }

  .project-card--purple .project-image {
    background: linear-gradient(135deg, #1e1b4b 0%, #4c1d95 100%);
  }

  .project-card--cyan .project-image {
    background: linear-gradient(135deg, #164e63 0%, #0e7490 100%);
  }

  .project-card--pink .project-image {
    background: linear-gradient(135deg, #4c1d42 0%, #be185d 100%);
  }

  .project-overlay {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(0, 0, 0, 0.5);
    opacity: 0;
    transition: opacity var(--transition-base);
  }

  .project-card:hover .project-overlay {
    opacity: 1;
  }

  .view-project {
    width: 60px;
    height: 60px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--gradient-primary);
    border-radius: 50%;
    transform: scale(0.8);
    transition: transform var(--transition-spring);
  }

  .project-card:hover .view-project {
    transform: scale(1);
  }

  .project-content {
    padding: 1.5rem;
  }

  .project-title {
    font-size: 1.25rem;
    margin-bottom: 0.75rem;
    transition: color var(--transition-fast);
  }

  .project-card:hover .project-title {
    color: var(--accent-blue);
  }

  .project-description {
    font-size: 0.95rem;
    margin-bottom: 1rem;
    line-height: 1.6;
  }

  .project-tech {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .tech-tag {
    padding: 0.35rem 0.75rem;
    background: rgba(59, 130, 246, 0.15);
    color: var(--accent-blue);
    border-radius: 50px;
    font-size: 0.75rem;
    font-weight: 500;
  }

  /* Cursor glow effect */
  .project-glow {
    position: absolute;
    width: 300px;
    height: 300px;
    border-radius: 50%;
    background: radial-gradient(
      circle,
      rgba(59, 130, 246, 0.3),
      transparent 70%
    );
    pointer-events: none;
    transform: translate(-50%, -50%);
    opacity: 0;
    transition: opacity var(--transition-fast);
    z-index: -1;
  }

  /* Modal Styles */
  .modal-overlay {
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.8);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 2rem;
    z-index: 2000;
    opacity: 0;
    visibility: hidden;
    transition: all var(--transition-base);
  }

  .modal-overlay.active {
    opacity: 1;
    visibility: visible;
  }

  .modal-container {
    position: relative;
    width: 100%;
    max-width: 600px;
    max-height: 90vh;
    background: var(--bg-dark);
    border: 1px solid var(--glass-border);
    border-radius: 24px;
    overflow: hidden;
    overflow-y: auto;
  }

  .modal-close {
    position: absolute;
    top: 1rem;
    right: 1rem;
    width: 44px;
    height: 44px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(0, 0, 0, 0.5);
    border: none;
    border-radius: 50%;
    color: white;
    cursor: pointer;
    z-index: 10;
    transition: all var(--transition-fast);
  }

  .modal-close:hover {
    background: rgba(0, 0, 0, 0.8);
    transform: rotate(90deg);
  }

  .modal-header {
    height: 200px;
    position: relative;
  }

  .modal-body {
    padding: 2rem;
  }

  .modal-title {
    font-size: 1.75rem;
    margin-bottom: 1rem;
  }

  .modal-description {
    font-size: 1rem;
    line-height: 1.8;
    margin-bottom: 2rem;
  }

  .modal-section {
    margin-bottom: 1.5rem;
  }

  .modal-section h4 {
    font-size: 0.875rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--text-muted);
    margin-bottom: 0.75rem;
  }

  .modal-features {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .feature-tag {
    padding: 0.5rem 1rem;
    background: rgba(16, 185, 129, 0.15);
    color: var(--accent-green);
    border-radius: 50px;
    font-size: 0.85rem;
    font-weight: 500;
  }

  .modal-tech {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .modal-actions {
    display: flex;
    gap: 1rem;
    margin-top: 2rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--glass-border);
  }

  .modal-actions .btn-primary,
  .modal-actions .btn-secondary {
    flex: 1;
    justify-content: center;
  }

  .modal-actions .btn-secondary {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 1rem 1.5rem;
    background: transparent;
    color: var(--text-primary);
    font-weight: 600;
    border: 1px solid var(--glass-border);
    border-radius: 50px;
    text-decoration: none;
    transition: all var(--transition-base);
  }

  .modal-actions .btn-secondary:hover {
    background: var(--glass-bg);
    border-color: var(--accent-cyan);
    color: var(--accent-cyan);
  }

  @media (max-width: 768px) {
    .projects-grid {
      grid-template-columns: 1fr;
    }

    .modal-overlay {
      padding: 1rem;
    }

    .modal-actions {
      flex-direction: column;
    }
  }
</style>
