---
const links = [
  { label: 'Work', href: '#work' },
  { label: 'Approach', href: '#approach' },
  { label: 'Contact', href: '#contact' },
];
---

<nav class="nav" id="nav">
  <div class="nav-inner">
    <a href="#home" class="nav-logo">HK</a>
    <div class="nav-links">
      {links.map(link => (
        <a href={link.href} class="nav-link" data-section={link.href.slice(1)}>{link.label}</a>
      ))}
    </div>
  </div>
</nav>

<script>
  (function() {
    var nav = document.getElementById('nav');
    var ticking = false;

    var navLinks = document.querySelectorAll('.nav-link');
    var sections = /** @type {NodeListOf<HTMLElement>} */ (document.querySelectorAll('section[id]'));

    function onScroll() {
      if (nav) {
        nav.classList.toggle('nav--scrolled', window.scrollY > 50);
      }

      var scrollPos = window.scrollY + 100;
      var activeId: string | null = null;

      sections.forEach(function(s) {
        var el = s as HTMLElement;
        var top = el.offsetTop;
        var bottom = top + el.offsetHeight;
        if (scrollPos >= top && scrollPos < bottom) {
          activeId = el.getAttribute('id');
        }
      });

      if (!activeId && sections.length > 0) {
        var lastSection = sections[sections.length - 1] as HTMLElement;
        if (window.scrollY + window.innerHeight >= lastSection.offsetTop + lastSection.offsetHeight) {
          activeId = lastSection.getAttribute('id');
        }
      }

      navLinks.forEach(function(link) {
        var section = link.getAttribute('data-section');
        link.classList.toggle('nav-link--active', section === activeId);
      });
    }

    window.addEventListener('scroll', function() {
      if (!ticking) {
        requestAnimationFrame(function() {
          onScroll();
          ticking = false;
        });
        ticking = true;
      }
    });

    onScroll();
  })();
</script>

<style>
  .nav {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    z-index: 100;
    padding: var(--space-4) 0;
    background: var(--bg-secondary);
    border-bottom: 1px solid var(--border);
    transition: box-shadow var(--transition);
  }

  .nav--scrolled {
    box-shadow: 0 1px 4px rgba(0, 0, 0, 0.04);
  }

  .nav-inner {
    max-width: var(--content-wide);
    margin: 0 auto;
    padding: 0 var(--space-5);
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .nav-logo {
    font-size: 1.125rem;
    font-weight: 700;
    letter-spacing: -0.02em;
  }

  .nav-links {
    display: flex;
    gap: var(--space-6);
  }

  .nav-link {
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--text-secondary);
    position: relative;
    transition: color var(--transition);
  }

  .nav-link::after {
    content: '';
    position: absolute;
    bottom: -2px;
    left: 0;
    width: 0;
    height: 1px;
    background: var(--text-primary);
    transition: width var(--transition);
  }

  .nav-link:hover {
    color: var(--text-primary);
  }

  .nav-link:hover::after {
    width: 100%;
  }

  .nav-link--active {
    color: var(--text-primary);
  }

  .nav-link--active::after {
    width: 100%;
  }

  @media (max-width: 640px) {
    .nav-links {
      display: none;
    }
  }
</style>
