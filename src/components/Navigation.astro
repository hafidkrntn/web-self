---
const links = [
  { label: 'Work', href: '#work' },
  { label: 'Approach', href: '#approach' },
  { label: 'Contact', href: '#contact' },
];
---

<nav class="nav">
  <div class="nav-inner">
    <a href="#home" class="nav-logo">HK</a>
    <div class="nav-links" id="nav-links">
      {links.map(link => (
        <a href={link.href} class="nav-link" data-section={link.href.slice(1)}>{link.label}</a>
      ))}
    </div>
  </div>
</nav>

<script>
  (function() {
    var navLinks = document.querySelectorAll('.nav-link');
    var sections = document.querySelectorAll('section[id]');

    function onScroll() {
      var scrollPos = window.scrollY + 100;
      var activeId: string | null = null;

      sections.forEach(function(s) {
        var el = s as HTMLElement;
        var top = el.offsetTop;
        var bottom = top + el.offsetHeight;
        if (scrollPos >= top && scrollPos < bottom) {
          activeId = el.getAttribute('id');
        }
      });

      if (!activeId && sections.length > 0) {
        var lastSection = sections[sections.length - 1] as HTMLElement;
        if (window.scrollY + window.innerHeight >= lastSection.offsetTop + lastSection.offsetHeight) {
          activeId = lastSection.getAttribute('id');
        }
      }

      navLinks.forEach(function(link) {
        var section = link.getAttribute('data-section');
        if (section === activeId) {
          link.classList.add('nav-link--active');
        } else {
          link.classList.remove('nav-link--active');
        }
      });
    }

    var ticking = false;
    window.addEventListener('scroll', function() {
      if (!ticking) {
        requestAnimationFrame(function() {
          onScroll();
          ticking = false;
        });
        ticking = true;
      }
    });

    onScroll();
  })();
</script>

<style>
  .nav {
    background: var(--bg-secondary);
    border-bottom: 1px solid var(--border);
    width: 100%;
  }

  .nav-inner {
    max-width: var(--content-wide);
    margin: 0 auto;
    padding: var(--space-4) var(--space-5);
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .nav-logo {
    font-family: var(--font-display);
    font-size: 1.25rem;
    font-weight: 700;
    font-style: italic;
    letter-spacing: -0.02em;
    color: var(--text-primary);
  }

  .nav-links {
    display: flex;
    gap: var(--space-6);
  }

  .nav-link {
    font-family: var(--font-sans);
    font-size: 0.8125rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--text-muted);
    position: relative;
    padding-bottom: 2px;
    font-style: normal;
  }

  .nav-link::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    width: 0;
    height: 1px;
    background: var(--text-primary);
    transition: width var(--transition);
  }

  .nav-link:hover {
    color: var(--text-primary);
  }

  .nav-link:hover::after {
    width: 100%;
  }

  .nav-link--active {
    color: var(--text-primary);
  }

  .nav-link--active::after {
    width: 100%;
  }

  @media (max-width: 640px) {
    .nav-links {
      gap: var(--space-4);
    }

    .nav-link {
      font-size: 0.75rem;
    }
  }
</style>
