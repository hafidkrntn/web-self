---
import BrowserFrame from "./BrowserFrame.astro";
import DeviceFrame from "./DeviceFrame.astro";

const projects = [
  {
    id: "sito",
    title: "SITO",
    subtitle: "System Tracking Oil",
    type: "mobile",
    image: "/images/projects/sito.webp",
    role: "Software Engineer — Product Planning, UI/UX, Frontend, Backend, Database, Deployment",
    problem:
      "Most riders estimate oil replacement manually, which often results in replacing oil too early or too late. There is no simple application focused on personalized maintenance reminders.",
    solution:
      "Built as a mobile-first Progressive Web App using Astro for the frontend and Go for the backend with PostgreSQL as the database. Designed with a scalable architecture to support future features such as push notifications, maintenance history, and analytics.",
    highlights: [
      "Mobile-first PWA with Astro frontend and Go backend",
      "PostgreSQL-backed architecture designed for scalability",
      "Engineered to support push notifications, maintenance history, and analytics",
    ],
    stack: ["Astro", "Go", "PostgreSQL"],
    outcome:
      "Focused on balancing simplicity with scalability. The architecture is prepared for future growth while remaining easy to use.",
    link: null,
    demo: null,
  },
  {
    id: "erp",
    title: "ERP Platform",
    subtitle: "Purchasing, Sales, Inventory, Finance, and Reporting",
    type: "web",
    image: "/images/projects/erp.webp",
    role: "Software Engineer / Technical Lead — Frontend, Backend, Database, Infrastructure, Deployment, Architecture",
    problem:
      "The company required an integrated platform to streamline business processes, reduce manual work, and improve operational efficiency across multiple departments including purchasing, sales, inventory, warehouse management, distribution, finance, and reporting.",
    solution:
      "Built modular REST APIs using Go with PostgreSQL, Docker, Redis, and Linux. Focused on maintainability, performance optimization, clean database design, and scalable architecture.",
    highlights: [
      "Modular REST API architecture with Go and PostgreSQL",
      "Containerized deployment with Docker and Redis",
      "Performance optimization through clean database design",
    ],
    stack: ["Go", "PostgreSQL", "Docker", "Redis", "Linux"],
    outcome:
      "Improved application performance, standardized development practices, and built a maintainable system that supports long-term business growth.",
    link: null,
    demo: null,
  },
  {
    id: "denext",
    title: "Denext",
    subtitle: "Corporate Website for IT Consulting",
    type: "web",
    image: "/images/projects/denext.webp",
    role: "Software Engineer — Redesign, Responsiveness, Accessibility, SEO, Performance",
    problem:
      "The previous website lacked a clear visual hierarchy and did not effectively communicate the company's services.",
    solution:
      "Rebuilt with semantic HTML, modern CSS, and lightweight JavaScript, focusing on accessibility, responsive layouts, and Core Web Vitals.",
    highlights: [
      "Semantic HTML with modern CSS architecture",
      "Lightweight JavaScript for optimal performance",
      "Accessibility, responsive layouts, and Core Web Vitals optimization",
    ],
    stack: ["HTML", "CSS", "JavaScript"],
    outcome:
      "Delivered a cleaner user experience with improved responsiveness, maintainability, and website performance.",
    link: null,
    demo: "https://denext.id",
  },
  {
    id: "toko-emas",
    title: "Toko Emas Roma",
    subtitle: "Business Website with Technical SEO",
    type: "web",
    image: "/images/projects/toko-emas.webp",
    role: "Software Engineer — Frontend, SEO, Performance",
    problem:
      "The client needed a modern business website that could improve online visibility, load quickly across devices, and rank competitively on search engines.",
    solution:
      "Developed the website using Next.js and Tailwind CSS with a strong emphasis on technical SEO. Implemented semantic HTML, metadata optimization, structured data, responsive layouts, and performance best practices to achieve excellent Core Web Vitals.",
    highlights: [
      "Built with Next.js App Router and Tailwind CSS",
      "Technical SEO with metadata, sitemap, robots.txt, and structured data",
      "Optimized Core Web Vitals and page performance",
      "Responsive design across desktop, tablet, and mobile",
    ],
    stack: ["Next.js", "React", "Tailwind CSS", "TypeScript"],
    outcome:
      "Delivered a fast, SEO-friendly business website that ranks highly for relevant search keywords while providing a smooth experience across all devices.",
    link: null,
    demo: "https://www.tokomasroma.com/",
  },
];
---

<section id="work" class="projects-section fade-in">
  <div class="projects-inner">
    <span class="section-number">02</span>
    <h2 class="label projects-label">Featured Projects</h2>
    <p class="section-desc">Selected work. No shared theme. No shared stack.</p>
    <div class="rule"></div>

    {projects.map((project, idx) => (
      <article class="project">
        <span class="project-number">{(idx + 1).toString().padStart(3, '0')}</span>
        <div class="project-layout">
          {project.image ? (
            <div class="project-visual">
              {project.type === "mobile" ? (
                <DeviceFrame src={project.image} alt={`${project.title} screenshot`} />
              ) : (
                <BrowserFrame
                  src={project.image}
                  alt={`${project.title} screenshot`}
                  url={project.demo || project.id + ".dev"}
                />
              )}
            </div>
          ) : null}
          <div class="project-content">
            <h3 class="project-title">{project.title}</h3>
            {project.subtitle ? <p class="project-subtitle label">{project.subtitle}</p> : null}
            <p class="project-role">{project.role}</p>

            <div class="rule--mini"></div>

            <div class="project-detail">
              <span class="detail-label label">Problem</span>
              <p class="detail-text">{project.problem}</p>
            </div>

            <div class="project-detail">
              <span class="detail-label label">Solution</span>
              <p class="detail-text">{project.solution}</p>
            </div>

            <div class="project-detail">
              <span class="detail-label label">Highlights</span>
              <ul class="detail-list">
                {project.highlights.map((h) => (
                  <li class="detail-item">{h}</li>
                ))}
              </ul>
            </div>

            <div class="project-detail">
              <span class="detail-label label">Stack</span>
              <div class="project-tags">
                {project.stack.map((tech) => (
                  <span class="tag">{tech}</span>
                ))}
              </div>
            </div>

            <div class="project-detail">
              <span class="detail-label label">Outcome</span>
              <p class="detail-text">{project.outcome}</p>
            </div>

            {project.link || project.demo ? (
              <div class="project-actions">
                {project.link && (
                  <a href={project.link} target="_blank" rel="noopener noreferrer" class="action-link">
                    Source Code
                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                      <path d="M7 17L17 7M17 7H7M17 7V17"/>
                    </svg>
                  </a>
                )}
                {project.demo && (
                  <a href={project.demo} target="_blank" rel="noopener noreferrer" class="action-link">
                    Live Site
                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                      <path d="M18 13v6a2 2 0 01-2 2H5a2 2 0 01-2-2V8a2 2 0 012-2h6M15 3h6v6M10 14L21 3"/>
                    </svg>
                  </a>
                )}
              </div>
            ) : null}
          </div>
        </div>
      </article>
    ))}
  </div>
</section>

<style>
  .projects-section {
    padding: var(--space-9) var(--space-5);
    max-width: var(--content-full);
    margin: 0 auto;
  }

  .projects-label {
    margin-bottom: var(--space-3);
  }

  .section-desc {
    font-size: 0.9375rem;
    color: var(--text-secondary);
    margin-bottom: 0;
  }

  .project {
    margin-top: var(--space-9);
    padding-top: var(--space-9);
    border-top: 1px solid var(--border);
  }

  .project:first-of-type {
    margin-top: 0;
    padding-top: 0;
    border-top: none;
  }

  .project-number {
    display: block;
    font-family: var(--font-sans);
    font-size: 0.6875rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    color: var(--text-muted);
    margin-bottom: var(--space-5);
    font-style: normal;
    font-variant-numeric: tabular-nums;
  }

  .project-layout {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-8);
    align-items: start;
  }

  .project-visual {
    max-width: 100%;
  }

  .project-content {
    padding-top: var(--space-1);
  }

  .project-title {
    margin-bottom: var(--space-2);
  }

  .project-subtitle {
    margin-bottom: var(--space-4);
    display: block;
  }

  .project-role {
    font-size: 0.9375rem;
    color: var(--text-secondary);
    line-height: 1.6;
    margin-bottom: 0;
  }

  .project-detail {
    margin-top: var(--space-6);
  }

  .detail-label {
    display: block;
    margin-bottom: var(--space-2);
  }

  .detail-text {
    font-size: 0.9375rem;
    color: var(--text-secondary);
    line-height: 1.7;
  }

  .detail-list {
    list-style: none;
    padding: 0;
  }

  .detail-item {
    position: relative;
    padding-left: var(--space-4);
    font-size: 0.9375rem;
    color: var(--text-secondary);
    line-height: 1.7;
    margin-bottom: var(--space-1);
  }

  .detail-item::before {
    content: "";
    position: absolute;
    left: 0;
    top: 0.7em;
    width: 4px;
    height: 4px;
    border-radius: 50%;
    background: var(--text-muted);
  }

  .project-tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
  }

  .tag {
    display: inline-block;
    font-family: var(--font-sans);
    font-size: 0.75rem;
    font-weight: 500;
    padding: var(--space-1) var(--space-3);
    background: oklch(0.94 0.005 85);
    color: var(--text-secondary);
    letter-spacing: 0.02em;
    font-style: normal;
  }

  .project-actions {
    display: flex;
    gap: var(--space-6);
    margin-top: var(--space-7);
    padding-top: var(--space-6);
    border-top: 1px solid var(--border);
  }

  .action-link {
    display: inline-flex;
    align-items: center;
    gap: var(--space-1);
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--text-secondary);
    transition: color var(--transition), gap var(--transition);
  }

  .action-link:hover {
    color: var(--accent);
    gap: var(--space-2);
  }

  .action-link svg {
    transition: transform var(--transition);
  }

  .action-link:hover svg {
    transform: translate(2px, -2px);
  }

  @media (max-width: 900px) {
    .project-layout {
      grid-template-columns: 1fr;
      gap: var(--space-6);
    }

    .project-visual {
      max-width: 500px;
    }
  }
</style>
