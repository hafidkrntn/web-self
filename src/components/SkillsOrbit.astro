---
/**
 * SkillsOrbit.astro
 * Orbital skills display with 3D rotation effect and popup details
 */
const skills = [
  {
    name: "TypeScript",
    icon: "https://cdn.jsdelivr.net/gh/devicons/devicon/icons/typescript/typescript-original.svg",
    color: "#3178C6",
    level: 85,
    description:
      "Strong typing, scalable frontend and backend codebases, and improved developer experience.",
    experience: "2+ years",
  },
  {
    name: "Next.js",
    icon: "https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/nextjs/nextjs-original.svg",
    color: "#FFFFFF",
    level: 88,
    description: "SSR, SSG, API routes, and full-stack React applications.",
    experience: "2+ years",
  },
  {
    name: "Astro",
    icon: "https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/astro/astro-original.svg",
    color: "#FF5D01",
    level: 85,
    description:
      "Static site generation, content collections, and integrations.",
    experience: "1+ year",
  },
  {
    name: "Golang",
    icon: "https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/go/go-original.svg",
    color: "#00ADD8",
    level: 80,
    description: "Concurrency, Gin framework, REST APIs, and backend services.",
    experience: "2+ years",
  },
  {
    name: "PHP",
    icon: "https://cdn.jsdelivr.net/gh/devicons/devicon/icons/php/php-original.svg",
    color: "#777BB4",
    level: 85,
    description: "Backend development, REST APIs, and server-side rendering.",
    experience: "1+ years",
  },
  {
    name: "CodeIgniter 3",
    icon: "https://cdn.jsdelivr.net/gh/devicons/devicon/icons/codeigniter/codeigniter-plain.svg",
    color: "#EE4623",
    level: 83,
    description:
      "MVC architecture, legacy system maintenance, and performance optimization.",
    experience: "1+ years",
  },
  {
    name: "jQuery",
    icon: "https://cdn.jsdelivr.net/gh/devicons/devicon/icons/jquery/jquery-original.svg",
    color: "#0769AD",
    level: 80,
    description: "DOM manipulation, AJAX, and legacy frontend integrations.",
    experience: "1+ years",
  },
  {
    name: "PostgreSQL",
    icon: "https://cdn.jsdelivr.net/gh/devicons/devicon/icons/postgresql/postgresql-original.svg",
    color: "#4169E1",
    level: 78,
    description:
      "Complex queries, indexing strategies, and database optimization.",
    experience: "1+ year",
  },
  {
    name: "MongoDB",
    icon: "https://cdn.jsdelivr.net/gh/devicons/devicon/icons/mongodb/mongodb-original.svg",
    color: "#47A248",
    level: 82,
    description: "Schema design, aggregation pipelines, and Mongoose ODM.",
    experience: "1+ year",
  },
  {
    name: "SQL Server",
    icon: "https://cdn.jsdelivr.net/gh/devicons/devicon/icons/microsoftsqlserver/microsoftsqlserver-plain.svg",
    color: "#CC2927",
    level: 85,
    description:
      "Stored procedures, complex joins, reporting, and query optimization.",
    experience: "1+ years",
  },
  {
    name: "Docker",
    icon: "https://cdn.jsdelivr.net/gh/devicons/devicon/icons/docker/docker-original.svg",
    color: "#2496ED",
    level: 75,
    description: "Containerization, Docker Compose, and CI/CD workflows.",
    experience: "1+ year",
  },
  {
    name: "Jenkins",
    icon: "https://cdn.jsdelivr.net/gh/devicons/devicon/icons/jenkins/jenkins-original.svg",
    color: "#D24939",
    level: 78,
    description:
      "CI/CD pipelines, automated builds, Docker-based deployments, and job orchestration.",
    experience: "1+ year",
  },
];
---

<section id="skills" class="skills section">
  <div class="container">
    <div class="section-header">
      <span class="section-label">Expertise</span>
      <h2>Skills & <span class="gradient-text">Technologies</span></h2>
      <p class="section-description">
        Technologies I've been working with recently to build modern,
        performant, and scalable applications.
        <br /><strong style="color: var(--accent-cyan);"
          >Click on a skill to see details!</strong
        >
      </p>
    </div>

    <div class="skills-showcase">
      <!-- Central element -->
      <div class="skills-center">
        <div class="center-glow"></div>
        <span class="center-text">12+</span>
        <span class="center-label">Technologies</span>
      </div>

      <!-- Skills grid -->
      <div class="skills-grid">
        {
          skills.map((skill, index) => (
            <div
              class="skill-card"
              style={`--skill-color: ${skill.color}; --index: ${index}`}
              data-skill={JSON.stringify(skill)}
            >
              <div class="skill-icon-wrapper">
                <img
                  src={skill.icon}
                  alt={skill.name}
                  class="skill-icon"
                  loading="lazy"
                />
              </div>
              <span class="skill-name">{skill.name}</span>
              <div class="skill-glow" />
            </div>
          ))
        }
      </div>
    </div>
  </div>
</section>

<!-- Skill Modal -->
<div class="skill-modal-overlay" id="skill-modal">
  <div class="skill-modal-container">
    <button
      class="skill-modal-close"
      id="skill-modal-close"
      aria-label="Close modal"
    >
      <svg
        width="20"
        height="20"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
      >
        <path d="M18 6L6 18M6 6l12 12"></path>
      </svg>
    </button>

    <div class="skill-modal-content">
      <div class="skill-modal-icon" id="skill-modal-icon">
        <!-- Icon will be inserted here -->
      </div>

      <h3 class="skill-modal-title" id="skill-modal-title">Skill Name</h3>

      <div class="skill-modal-level">
        <div class="level-bar">
          <div class="level-fill" id="skill-modal-level"></div>
        </div>
        <span class="level-text" id="skill-modal-level-text">0%</span>
      </div>

      <p class="skill-modal-description" id="skill-modal-description">
        Description
      </p>

      <div class="skill-modal-experience">
        <svg
          width="16"
          height="16"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
        >
          <circle cx="12" cy="12" r="10"></circle>
          <path d="M12 6v6l4 2"></path>
        </svg>
        <span id="skill-modal-experience">Experience</span>
      </div>
    </div>
  </div>
</div>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  function initSkillAnimations() {
    // Make sure elements are visible first
    gsap.set(".skill-card", { opacity: 1, y: 0, scale: 1 });
    gsap.set(".skills-center", { opacity: 1, scale: 1 });

    // Skill cards entrance animation
    gsap.from(".skill-card", {
      scrollTrigger: {
        trigger: ".skills-grid",
        start: "top 85%",
        once: true,
      },
      y: 60,
      opacity: 0,
      scale: 0.8,
      duration: 0.6,
      stagger: {
        amount: 0.8,
        grid: "auto",
        from: "center",
      },
      ease: "back.out(1.7)",
    });

    // Center element animation
    gsap.from(".skills-center", {
      scrollTrigger: {
        trigger: ".skills-showcase",
        start: "top 75%",
        once: true,
      },
      scale: 0,
      opacity: 0,
      duration: 1,
      ease: "elastic.out(1, 0.5)",
    });
  }

  // Wait for page to be fully loaded
  if (document.readyState === "complete") {
    initSkillAnimations();
    ScrollTrigger.refresh();
  } else {
    window.addEventListener("load", () => {
      initSkillAnimations();
      ScrollTrigger.refresh();
    });
  }

  // Modal elements
  const skillModal = document.getElementById("skill-modal");
  const skillModalClose = document.getElementById("skill-modal-close");
  const skillModalIcon = document.getElementById("skill-modal-icon");
  const skillModalTitle = document.getElementById("skill-modal-title");
  const skillModalLevel = document.getElementById("skill-modal-level");
  const skillModalLevelText = document.getElementById("skill-modal-level-text");
  const skillModalDescription = document.getElementById(
    "skill-modal-description",
  );
  const skillModalExperience = document.getElementById(
    "skill-modal-experience",
  );

  // Open skill modal
  function openSkillModal(skillData: any) {
    if (!skillModal) return;

    // Set content
    if (skillModalIcon) {
      skillModalIcon.innerHTML = `<img src="${skillData.icon}" alt="${skillData.name}" />`;
      skillModalIcon.style.setProperty("--skill-color", skillData.color);
    }
    if (skillModalTitle) skillModalTitle.textContent = skillData.name;
    if (skillModalDescription)
      skillModalDescription.textContent = skillData.description;
    if (skillModalExperience)
      skillModalExperience.textContent = skillData.experience;
    if (skillModalLevelText)
      skillModalLevelText.textContent = `${skillData.level}%`;

    // Show modal
    skillModal.classList.add("active");
    document.body.style.overflow = "hidden";

    // Animate modal in
    gsap.fromTo(
      skillModal.querySelector(".skill-modal-container"),
      { scale: 0.8, opacity: 0, y: 20 },
      { scale: 1, opacity: 1, y: 0, duration: 0.4, ease: "back.out(1.7)" },
    );

    // Animate level bar
    if (skillModalLevel) {
      gsap.fromTo(
        skillModalLevel,
        { width: "0%" },
        {
          width: `${skillData.level}%`,
          duration: 1,
          delay: 0.3,
          ease: "power2.out",
        },
      );
    }
  }

  // Close skill modal
  function closeSkillModal() {
    if (!skillModal) return;

    gsap.to(skillModal.querySelector(".skill-modal-container"), {
      scale: 0.8,
      opacity: 0,
      y: 20,
      duration: 0.3,
      ease: "power2.in",
      onComplete: () => {
        skillModal.classList.remove("active");
        document.body.style.overflow = "";
      },
    });
  }

  // Event listeners
  document.querySelectorAll(".skill-card").forEach((card) => {
    const cardEl = card as HTMLElement;

    // Click to open modal
    cardEl.addEventListener("click", () => {
      const skillData = cardEl.dataset.skill;
      if (skillData) {
        openSkillModal(JSON.parse(skillData));
      }
    });

    // Hover animations
    cardEl.addEventListener("mouseenter", () => {
      gsap.to(cardEl, {
        y: -15,
        scale: 1.1,
        duration: 0.3,
        ease: "power2.out",
      });
    });

    cardEl.addEventListener("mouseleave", () => {
      gsap.to(cardEl, {
        y: 0,
        scale: 1,
        duration: 0.3,
        ease: "power2.out",
      });
    });
  });

  // Close modal events
  skillModalClose?.addEventListener("click", closeSkillModal);
  skillModal?.addEventListener("click", (e) => {
    if (e.target === skillModal) closeSkillModal();
  });
  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape" && skillModal?.classList.contains("active")) {
      closeSkillModal();
    }
  });
</script>

<style>
  .skills {
    position: relative;
    overflow: hidden;
  }

  .section-header {
    text-align: center;
    margin-bottom: 4rem;
  }

  .section-label {
    display: inline-block;
    padding: 0.5rem 1rem;
    background: var(--glass-bg);
    border: 1px solid var(--glass-border);
    border-radius: 50px;
    font-size: 0.875rem;
    color: var(--accent-cyan);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: 1rem;
  }

  .section-description {
    max-width: 500px;
    margin: 1rem auto 0;
  }

  .skills-showcase {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 3rem;
  }

  /* Central Element */
  .skills-center {
    position: relative;
    width: 140px;
    height: 140px;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    background: var(--glass-bg);
    border: 1px solid var(--glass-border);
    border-radius: 50%;
    z-index: 10;
  }

  .center-glow {
    position: absolute;
    inset: -20px;
    background: radial-gradient(
      circle,
      rgba(59, 130, 246, 0.3),
      transparent 70%
    );
    border-radius: 50%;
    animation: pulse 3s ease-in-out infinite;
  }

  .center-text {
    font-family: var(--font-display);
    font-size: 2.5rem;
    font-weight: 700;
    background: var(--gradient-primary);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    position: relative;
    z-index: 1;
  }

  .center-label {
    font-size: 0.75rem;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    position: relative;
    z-index: 1;
  }

  /* Skills Grid */
  .skills-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(120px, 1fr));
    gap: 1.25rem;
    max-width: 800px;
    width: 100%;
  }

  .skill-card {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
    padding: 1.5rem 1rem;
    background: var(--glass-bg);
    border: 1px solid var(--glass-border);
    border-radius: 20px;
    cursor: pointer;
    transition: all var(--transition-base);
    overflow: hidden;
  }

  .skill-card:hover {
    border-color: var(--skill-color);
    background: var(--glass-bg-hover);
  }

  .skill-icon-wrapper {
    width: 50px;
    height: 50px;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    z-index: 1;
  }

  .skill-icon {
    width: 100%;
    height: 100%;
    object-fit: contain;
    transition: all var(--transition-base);
    filter: drop-shadow(0 0 0 transparent);
  }

  .skill-card:hover .skill-icon {
    transform: rotateY(360deg);
    filter: drop-shadow(0 0 15px var(--skill-color));
  }

  .skill-name {
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--text-secondary);
    text-align: center;
    position: relative;
    z-index: 1;
    transition: color var(--transition-fast);
  }

  .skill-card:hover .skill-name {
    color: var(--skill-color);
  }

  /* Skill card glow */
  .skill-glow {
    position: absolute;
    inset: 0;
    background: radial-gradient(
      circle at center,
      var(--skill-color),
      transparent 70%
    );
    opacity: 0;
    transition: opacity var(--transition-base);
  }

  .skill-card:hover .skill-glow {
    opacity: 0.1;
  }

  @keyframes pulse {
    0%,
    100% {
      transform: scale(1);
      opacity: 0.5;
    }
    50% {
      transform: scale(1.1);
      opacity: 0.3;
    }
  }

  /* Skill Modal */
  .skill-modal-overlay {
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.8);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 2rem;
    z-index: 2000;
    opacity: 0;
    visibility: hidden;
    transition: all var(--transition-base);
  }

  .skill-modal-overlay.active {
    opacity: 1;
    visibility: visible;
  }

  .skill-modal-container {
    position: relative;
    width: 100%;
    max-width: 400px;
    background: var(--bg-dark);
    border: 1px solid var(--glass-border);
    border-radius: 24px;
    overflow: hidden;
    text-align: center;
  }

  .skill-modal-close {
    position: absolute;
    top: 1rem;
    right: 1rem;
    width: 36px;
    height: 36px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--glass-bg);
    border: 1px solid var(--glass-border);
    border-radius: 50%;
    color: var(--text-muted);
    cursor: pointer;
    z-index: 10;
    transition: all var(--transition-fast);
  }

  .skill-modal-close:hover {
    background: var(--glass-bg-hover);
    color: var(--text-primary);
    transform: rotate(90deg);
  }

  .skill-modal-content {
    padding: 2.5rem 2rem;
  }

  .skill-modal-icon {
    width: 80px;
    height: 80px;
    margin: 0 auto 1.5rem;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--glass-bg);
    border-radius: 20px;
    padding: 1rem;
  }

  .skill-modal-icon img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    filter: drop-shadow(0 0 20px var(--skill-color, var(--accent-blue)));
  }

  .skill-modal-title {
    font-size: 1.5rem;
    margin-bottom: 1.25rem;
  }

  .skill-modal-level {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 1.5rem;
  }

  .level-bar {
    flex: 1;
    height: 8px;
    background: var(--glass-bg);
    border-radius: 4px;
    overflow: hidden;
  }

  .level-fill {
    height: 100%;
    background: var(--gradient-primary);
    border-radius: 4px;
    width: 0%;
  }

  .level-text {
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--accent-blue);
    min-width: 40px;
  }

  .skill-modal-description {
    font-size: 0.95rem;
    line-height: 1.7;
    margin-bottom: 1.5rem;
  }

  .skill-modal-experience {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem 1rem;
    background: var(--glass-bg);
    border-radius: 50px;
    font-size: 0.85rem;
    color: var(--accent-cyan);
  }

  @media (max-width: 768px) {
    .skills-grid {
      grid-template-columns: repeat(3, 1fr);
      gap: 1rem;
    }

    .skill-card {
      padding: 1rem 0.75rem;
    }

    .skill-icon-wrapper {
      width: 40px;
      height: 40px;
    }

    .skill-name {
      font-size: 0.75rem;
    }

    .skill-modal-overlay {
      padding: 1rem;
    }
  }
</style>
