---

<section id="contact" class="contact section">
  <div class="container">
    <div class="contact-wrapper">
      <div class="contact-content">
        <span class="section-label">Contact</span>
        <h2>Let's Work <span class="gradient-text">Together</span></h2>
        <p class="contact-description">
          Have a project in mind or want to collaborate? I'm always open to
          discussing new opportunities and ideas. Let's create something
          amazing!
        </p>

        <div class="contact-cta">
          <a href="mailto:hello@example.com" class="btn-primary">
            <span>Send Message</span>
            <svg
              width="20"
              height="20"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
            >
              <path d="M22 2L11 13M22 2l-7 20-4-9-9-4 20-7z"></path>
            </svg>
          </a>
        </div>
      </div>

      <div class="social-grid">
        {
          socialLinks.map((link, index) => (
            <a
              href={link.href}
              class="social-card"
              style={`--link-color: ${link.color}; --index: ${index}`}
              target="_blank"
              rel="noopener noreferrer"
              aria-label={link.name}
            >
              <div class="social-icon" set:html={link.icon} />
              <span class="social-name">{link.name}</span>
              <div class="social-glow" />
            </a>
          ))
        }
      </div>
    </div>
  </div>
</section>

<!-- Footer -->
<footer class="footer">
  <div class="container">
    <div class="footer-content">
      <p class="copyright">
        © 2024 <span class="gradient-text">Creative Developer</span>. Built with
        Astro & Three.js
      </p>
      <div class="footer-decoration">
        <span class="decoration-line"></span>
        <span class="decoration-dot"></span>
        <span class="decoration-line"></span>
      </div>
    </div>
  </div>
</footer>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  // Contact content animation
  gsap.from(".contact-content > *", {
    scrollTrigger: {
      trigger: ".contact",
      start: "top 75%",
    },
    y: 50,
    opacity: 0,
    duration: 0.8,
    stagger: 0.15,
    ease: "power3.out",
  });

  // Social cards animation
  const socialGrid = document.querySelector(".social-grid");
  const socialCards = document.querySelectorAll(".social-card");

  // Check if already in view on page load
  if (socialGrid) {
    const rect = socialGrid.getBoundingClientRect();
    const isInView = rect.top < window.innerHeight * 0.8;

    if (isInView) {
      // Already in view - animate immediately
      gsap.fromTo(
        ".social-card",
        { scale: 0.8, opacity: 0 },
        {
          scale: 1,
          opacity: 1,
          duration: 0.6,
          stagger: 0.1,
          ease: "back.out(1.7)",
        },
      );
    } else {
      // Not in view - use scroll trigger
      gsap.from(".social-card", {
        scrollTrigger: {
          trigger: ".social-grid",
          start: "top 80%",
        },
        scale: 0.8,
        opacity: 0,
        duration: 0.6,
        stagger: 0.1,
        ease: "back.out(1.7)",
        immediateRender: false,
      });
    }
  }

  // 3D hover effect on social cards
  document.querySelectorAll(".social-card").forEach((card) => {
    const cardEl = card as HTMLElement;

    cardEl.addEventListener("mousemove", (e) => {
      const rect = cardEl.getBoundingClientRect();
      const x = e.clientX - rect.left;
      const y = e.clientY - rect.top;
      const centerX = rect.width / 2;
      const centerY = rect.height / 2;

      const rotateX = (y - centerY) / 10;
      const rotateY = (centerX - x) / 10;

      gsap.to(cardEl, {
        rotateX: -rotateX,
        rotateY: rotateY,
        scale: 1.05,
        duration: 0.3,
        ease: "power2.out",
        transformPerspective: 500,
      });
    });

    cardEl.addEventListener("mouseleave", () => {
      gsap.to(cardEl, {
        rotateX: 0,
        rotateY: 0,
        scale: 1,
        duration: 0.3,
        ease: "power2.out",
      });
    });
  });
</script>

<style>
  .contact {
    position: relative;
    overflow: hidden;
  }

  .contact-wrapper {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
  }

  .section-label {
    display: inline-block;
    padding: 0.5rem 1rem;
    background: var(--glass-bg);
    border: 1px solid var(--glass-border);
    border-radius: 50px;
    font-size: 0.875rem;
    color: var(--accent-pink);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: 1rem;
  }

  .contact-content h2 {
    margin-bottom: 1.5rem;
  }

  .contact-description {
    font-size: 1.1rem;
    line-height: 1.8;
    margin-bottom: 2rem;
  }

  .contact-cta {
    display: flex;
    gap: 1rem;
  }

  /* Social Grid */
  .social-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.25rem;
  }

  .social-card {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    padding: 2rem 1.5rem;
    background: var(--glass-bg);
    border: 1px solid var(--glass-border);
    border-radius: 20px;
    text-decoration: none;
    color: var(--text-primary);
    transition: all var(--transition-base);
    transform-style: preserve-3d;
    overflow: hidden;
  }

  .social-card:hover {
    border-color: var(--link-color);
    background: var(--glass-bg-hover);
    color: var(--link-color);
  }

  .social-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    transition: transform var(--transition-base);
  }

  .social-card:hover .social-icon {
    transform: scale(1.2) translateZ(20px);
  }

  .social-name {
    font-size: 0.9rem;
    font-weight: 600;
    transition: color var(--transition-fast);
  }

  .social-glow {
    position: absolute;
    inset: 0;
    background: radial-gradient(
      circle at center,
      var(--link-color),
      transparent 70%
    );
    opacity: 0;
    transition: opacity var(--transition-base);
  }

  .social-card:hover .social-glow {
    opacity: 0.15;
  }

  /* Footer */
  .footer {
    padding: 3rem 0;
    border-top: 1px solid var(--glass-border);
    margin-top: 4rem;
  }

  .footer-content {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.5rem;
    text-align: center;
  }

  .copyright {
    color: var(--text-muted);
    font-size: 0.9rem;
  }

  .footer-decoration {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .decoration-line {
    width: 40px;
    height: 1px;
    background: var(--gradient-primary);
  }

  .decoration-dot {
    width: 6px;
    height: 6px;
    background: var(--accent-blue);
    border-radius: 50%;
  }

  @media (max-width: 768px) {
    .contact-wrapper {
      grid-template-columns: 1fr;
      gap: 3rem;
    }

    .contact-content {
      text-align: center;
    }

    .contact-cta {
      justify-content: center;
    }

    .social-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
</style>
