---
const socialLinks = [
  { label: "GitHub", href: "https://github.com/hafidkrntn" },
  { label: "LinkedIn", href: "https://www.linkedin.com/in/muhamad-hafid-123958219/" },
  { label: "X", href: "https://x.com/hakun0318" },
];
const year = new Date().getFullYear();
---

<section id="contact" class="contact-section fade-in">
  <div class="contact-inner">
    <span class="section-number">04</span>
    <h2 class="label contact-label">Contact</h2>

    <p class="contact-statement">Let's work together.</p>

    <p class="contact-text">
      Whether you're building a product,<br />
      improving an existing system,<br />
      or just exploring an idea,<br />
      I'd be happy to hear from you.
    </p>

    <div class="contact-links">
      <a href="mailto:hafidkrntn@gmail.com" class="contact-link">hafidkrntn@gmail.com</a>
      {socialLinks.map((link) => (
        <a href={link.href} target="_blank" rel="noopener noreferrer" class="contact-link">
          {link.label}
        </a>
      ))}
    </div>

    <div class="rule"></div>

    <footer class="colophon">
      <p class="colophon-credit">Designed &amp; Engineered by <strong>Muhamad Hafid Kurnianton</strong></p>
      <p class="colophon-meta">HKLABS &copy; {year}</p>
    </footer>
  </div>
</section>

<style>
  .contact-section {
    padding: var(--space-9) var(--space-5) var(--space-9);
    max-width: var(--content-wide);
    margin: 0 auto;
  }

  .contact-label {
    margin-bottom: var(--space-6);
  }

  .contact-statement {
    font-family: var(--font-display);
    font-size: clamp(1.75rem, 3vw, 2.25rem);
    font-weight: 600;
    font-style: italic;
    line-height: 1.2;
    color: var(--text-primary);
    margin-bottom: var(--space-5);
  }

  .contact-text {
    font-size: 1rem;
    line-height: 1.7;
    color: var(--text-secondary);
    margin-bottom: var(--space-7);
    max-width: var(--content-narrow);
  }

  .contact-links {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-5) var(--space-7);
    margin-bottom: 0;
  }

  .contact-link {
    font-size: 0.9375rem;
    font-weight: 500;
    color: var(--text-secondary);
    transition: color var(--transition);
  }

  .contact-link:hover {
    color: var(--text-primary);
  }

  .colophon {
    padding-top: 0;
  }

  .colophon-credit {
    font-size: 0.8125rem;
    font-weight: 500;
    color: var(--text-muted);
    margin-bottom: var(--space-1);
  }

  .colophon-credit strong {
    font-weight: 600;
    color: var(--text-secondary);
  }

  .colophon-meta {
    font-size: 0.75rem;
    color: var(--text-muted);
  }

  @media (max-width: 640px) {
    .contact-section {
      padding: var(--space-9) var(--space-5) var(--space-8);
    }

    .contact-links {
      flex-direction: column;
      gap: var(--space-3);
    }
  }
</style>
