---
/**
 * Layout.astro
 * Main layout with smooth scroll and 3D scene
 */
import "../styles/global.css";
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />

		<!-- SEO Meta Tags -->
		<title>Hafid | Adaptive Developer</title>
		<meta
			name="description"
			content="I'm an Adaptive Developer who enjoys building efficient, scalable applications and learning new technologies to improve code quality and usability."
		/>
		<meta name="author" content="Hafid" />

		<!-- Open Graph -->
		<meta property="og:type" content="website" />
		<meta property="og:title" content="Hafid | Adaptive Developer" />
		<meta
			property="og:description"
			content="Building efficient, scalable applications with modern technologies."
		/>

		<!-- Preconnect to external resources -->
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link rel="preconnect" href="https://cdn.jsdelivr.net" />

		<meta name="generator" content={Astro.generator} />
	</head>
	<body>
		<!-- Scroll Progress Bar -->
		<div class="scroll-progress" id="scroll-progress"></div>

		<slot />

		<!-- Smooth Scroll Initialization -->
		<script>
			import Lenis from "lenis";
			import { gsap } from "gsap";
			import { ScrollTrigger } from "gsap/ScrollTrigger";

			gsap.registerPlugin(ScrollTrigger);

			// Initialize Lenis smooth scroll
			const lenis = new Lenis({
				duration: 1.2,
				easing: (t) => Math.min(1, 1.001 - Math.pow(2, -10 * t)),
				orientation: "vertical",
				gestureOrientation: "vertical",
				smoothWheel: true,
				wheelMultiplier: 1,
				touchMultiplier: 2,
			});

			// Connect Lenis to GSAP ScrollTrigger
			lenis.on("scroll", ScrollTrigger.update);

			gsap.ticker.add((time) => {
				lenis.raf(time * 1000);
			});

			gsap.ticker.lagSmoothing(0);

			// Scroll progress bar
			const scrollProgress = document.getElementById("scroll-progress");

			window.addEventListener("scroll", () => {
				const scrollTop =
					document.documentElement.scrollTop || document.body.scrollTop;
				const scrollHeight =
					document.documentElement.scrollHeight -
					document.documentElement.clientHeight;
				const progress = (scrollTop / scrollHeight) * 100;

				if (scrollProgress) {
					scrollProgress.style.width = `${progress}%`;
				}
			});

			// Page load animation
			document.body.classList.add("loaded");
		</script>
	</body>
</html>

<style is:global>
	/* Page load transition */
	body {
		opacity: 0;
		transition: opacity 0.5s ease;
	}

	body.loaded {
		opacity: 1;
	}
</style>
